<%= form_with(model: equipamento) do |form| %>
  <% if equipamento.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(equipamento.errors.count, "error") %> prohibited this equipamento from being saved:</h2>

      <ul>
        <% equipamento.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :tipo, style: "display: block" %>
    <%= form.select :tipo, ['Processador', 'Microcontrolador', 'Drone', 'Placa de Video'], selected: 'Microcontrolador' %>
  </div>


  <div>
    <%= form.label :condicao, style: "display: block" %>
    <%= form.select :condicao, ['Novo', 'Semi-Novo', 'Desgastado', 'Deteriorado'], selected: 'Novo' %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.select :status, ['Emprestado', 'Disponível', 'Indisponível'], selected: 'Disponível' %>
  </div>

    <div>
    <%= form.label :descricao, style: "display: block" %>
    <%= form.text_area :descricao %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
